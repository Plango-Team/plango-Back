# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/plango

# ── JWT ──────────────────────────────────────────────────
# Single access token — no refresh token needed
JWT_SECRET=replace_this_with_a_very_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Email (Gmail example) ─────────────────────────────────

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Auth App <noreply@yourapp.com>

# ── WhatsApp OTP ──────────────────────────────────────────
# Choose: twilio OR meta
WHATSAPP_PROVIDER=twilio

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API
META_WHATSAPP_TOKEN=your_meta_token
META_PHONE_NUMBER_ID=your_phone_number_id

# Language for all Meta templates (e.g. en_US, ar, fr, es)
# META_TEMPLATE_LANGUAGE=en_US

# Approved template names — create these in Meta Business Manager first
# Category: AUTHENTICATION or UTILITY
# Body variables: {{1}} = OTP code, {{2}} = expiry minutes
# META_TEMPLATE_VERIFY_PHONE=verify_phone_otp
# META_TEMPLATE_RESET_PASSWORD=reset_password_otp
# META_TEMPLATE_CHANGE_PHONE=change_phone_otp

# ── App Settings ──────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
SECURITY_LOCK_HOURS=24
DELETION_GRACE_HOURS=24